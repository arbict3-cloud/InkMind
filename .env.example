# ==========================================
# InkMind 开发环境配置
# ==========================================
# 复制此文件为 .env 后修改相应配置
# 注意：.env 文件不应提交到 git 仓库

# ==========================================
# 前端配置
# ==========================================
VITE_FRONTEND_PORT=5173

# ==========================================
# 后端配置
# ==========================================
VITE_BACKEND_HOST=127.0.0.1
VITE_BACKEND_PORT=8000

# ==========================================
# 数据库
# ==========================================
DATABASE_URL=sqlite:///./inkmind.db

# ==========================================
# JWT 认证
# ==========================================
SECRET_KEY=change-me-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ==========================================
# CORS
# ==========================================
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ==========================================
# 默认 LLM 提供商
# ==========================================
# 可选: openai / qwen / deepseek / minimax / moonshot / anthropic
DEFAULT_LLM_PROVIDER=openai

# ==========================================
# OpenAI（或兼容网关）
# ==========================================
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_SEND_TEMPERATURE=true
OPENAI_TIMEOUT=120.0

# ==========================================
# 通义千问（DashScope OpenAI 兼容）
# ==========================================
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo
QWEN_SEND_TEMPERATURE=true
QWEN_TIMEOUT=120.0

# ==========================================
# DeepSeek
# ==========================================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_SEND_TEMPERATURE=true
DEEPSEEK_TIMEOUT=120.0

# ==========================================
# MiniMax
# ==========================================
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2
MINIMAX_SEND_TEMPERATURE=true
MINIMAX_TIMEOUT=120.0

# ==========================================
# Kimi / Moonshot（月之暗面）
# ==========================================
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
MOONSHOT_MODEL=moonshot-v1-8k
MOONSHOT_SEND_TEMPERATURE=true
MOONSHOT_TIMEOUT=120.0

# ==========================================
# Anthropic（Claude Agent SDK 编排器）
# ==========================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ==========================================
# Claude Agent SDK 配置
# ==========================================
# Claude Code CLI 路径（默认自动检测，如需指定可填写绝对路径）
CLAUDE_CLI_PATH=
# Agent 最大推理轮数
AGENT_MAX_TURNS=30
# Agent 权限模式: default / acceptEdits / plan / bypassPermissions
AGENT_PERMISSION_MODE=bypassPermissions
# Agent 编排器使用的模型提供商（当没有 ANTHROPIC_API_KEY 时生效）
# 可选: deepseek / qwen / minimax / kimi / openai
AGENT_ORCHESTRATOR_PROVIDER=deepseek

# ==========================================
# OpenTelemetry（可选）
# ==========================================
OTEL_ENABLED=false
OTEL_SERVICE_NAME=inkmind-api
OTEL_EXPORTER_OTLP_ENDPOINT=

# ==========================================
# Prometheus（可选）
# ==========================================
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
