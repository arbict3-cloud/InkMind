# ==========================================
# InkMind 生产环境配置模板
# ==========================================
# 复制到项目根目录为 .env 后修改
# cp deploy/env.production.template /opt/inkmind/.env
# ==========================================

# Docker Compose 镜像配置（从镜像仓库拉取时需要）
# DOCKER_IMAGE_PREFIX 必须包含 GitHub 用户名/组织名（全小写）
# 例如: your-github-username/inkmind
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_PREFIX=your-github-username/inkmind
DOCKER_IMAGE_TAG=latest

# 数据库（SQLite，容器内路径）
DATABASE_URL=sqlite:///./inkmind.db

# JWT 认证（务必替换为随机长字符串！）
# 生成方法: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=REPLACE_ME_WITH_RANDOM_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS（替换为你的实际域名，多个用逗号分隔）
CORS_ORIGINS=http://your-domain.com,http://your-aliyun-ip

# 默认 LLM 提供商
# 可选: openai / qwen / deepseek / minimax / moonshot / anthropic
DEFAULT_LLM_PROVIDER=qwen

# 通义千问
QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo
QWEN_SEND_TEMPERATURE=true
QWEN_TIMEOUT=120.0

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_SEND_TEMPERATURE=true
DEEPSEEK_TIMEOUT=120.0

# Anthropic（Claude Agent SDK 编排器，可选）
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_MODEL=deepseek-v4-flash

# OpenAI（或兼容网关，可选）
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_SEND_TEMPERATURE=true
OPENAI_TIMEOUT=120.0

# MiniMax（可选）
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2
MINIMAX_SEND_TEMPERATURE=true
MINIMAX_TIMEOUT=120.0

# Kimi / Moonshot（可选）
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
MOONSHOT_MODEL=moonshot-v1-8k
MOONSHOT_SEND_TEMPERATURE=true
MOONSHOT_TIMEOUT=120.0

# Claude Agent SDK 配置
CLAUDE_CLI_PATH=
AGENT_MAX_TURNS=30
AGENT_PERMISSION_MODE=bypassPermissions
AGENT_ORCHESTRATOR_PROVIDER=deepseek

# OpenTelemetry（可选）
OTEL_ENABLED=false
OTEL_SERVICE_NAME=inkmind-api
OTEL_EXPORTER_OTLP_ENDPOINT=

# Prometheus（可选）
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
