{
  "name": "get_previous_chapters",
  "display_name": "获取前文概要",
  "description": "获取作品的前 N 章概要，用于了解故事进展。参数 limit 指定章节数量（默认3）。",
  "category": "context",
  "parameters": [
    {
      "name": "limit",
      "type": "integer",
      "description": "获取的章节数量，默认3",
      "required": false,
      "default": 3
    }
  ],
  "applicable_phases": ["chapter_summary", "chapter_content"],
  "user_callable": false,
  "requires_chapter": false,
  "requires_stream": false,
  "examples": ["获取前3章概要", "查看前文情节"]
}
